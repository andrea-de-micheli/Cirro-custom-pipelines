/*
 * Cirro compute configuration overrides for BAM-to-FASTQ-cellranger.
 * Merged on top of the pipeline's nextflow.config at runtime.
 */

process {
    // Retry each task once; if it still fails, ignore so the rest of the
    // pipeline keeps running. Important for batches with heterogeneous BAMs
    // where a few may be incompatible with bamtofastq (e.g. vdj all_contig.bam).
    errorStrategy = { task.attempt > 1 ? 'ignore' : 'retry' }
    maxRetries    = 1

    withName: 'BAM_TO_FASTQ' {
        cpus   = { params.threads as Integer }
        memory = { (params.memory_gb as Integer).GB * task.attempt }
        disk   = { "${(params.disk_gb as Integer) * task.attempt} GB" }
    }
}

aws {
    batch {
        jobRole = null
    }
}
