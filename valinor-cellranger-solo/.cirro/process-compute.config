/*
 * Cirro compute configuration overrides for valinor-cellranger-solo.
 *
 * Merged with the pipeline's base nextflow.config for AWS Batch execution.
 */

process {
    // Retry once, then ignore so one failing sample doesn't kill the batch.
    errorStrategy = { task.attempt > 1 ? 'ignore' : 'retry' }
    maxRetries    = 1

    withName: 'DOWNLOAD_REFERENCE' {
        cpus   = 2
        memory = '4 GB'
        disk   = '60 GB'
    }

    withName: 'CELLRANGER_COUNT' {
        cpus   = { params.cpus as Integer }
        memory = { "${(params.memory_gb as Integer)} GB" }
        disk   = { "${(params.disk_gb as Integer) * task.attempt} GB" }
    }
}

aws {
    batch {
        jobRole = null
    }
}
