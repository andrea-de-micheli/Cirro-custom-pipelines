/*
 * Cirro compute configuration overrides for valinor-cellranger.
 *
 * Merged with the pipeline's base nextflow.config for AWS Batch execution.
 */

process {
    errorStrategy = 'retry'
    maxRetries    = 1

    withName: 'DOWNLOAD_REFERENCE' {
        cpus   = 2
        memory = '4 GB'
        disk   = '60 GB'
    }

    withName: 'CELLRANGER_MULTI' {
        cpus   = { params.cpus as Integer }
        memory = { "${(params.memory_gb as Integer)} GB" }
        disk   = { "${(params.disk_gb as Integer) * task.attempt} GB" }
    }
}

aws {
    batch {
        jobRole = null
    }
}
